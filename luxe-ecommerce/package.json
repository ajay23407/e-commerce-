{
  "name": "luxe-ecommerce",
  "version": "1.0.0",
  "description": "Full-stack luxury ecommerce platform",
  "main": "backend/server.js",
  "scripts": {
    "start": "node backend/server.js",
    "dev": "nodemon backend/server.js",
